generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  name              String
  email             String            @unique
  passwordHash      String?
  role              Role
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  otp               String?
  otpExpiresAt      DateTime?
  emailVerified     DateTime?
  auditLogs         AuditLog[]
  onboardedStudents Student[]
  notifications     Notification[]
  imageUrl          String?
  lead              Lead?             @relation("LeadUser")
  agentProfile      AgentProfile?
  counselorProfile  CounselorProfile?
  activities        LeadActivity[]
  assignedByLeads   LeadAssignment[]  @relation("AssignedBy")
  assignedLeads     LeadAssignment[]  @relation("AssignedTo")
  documents         LeadDocument[]
  tasks             LeadTask[]
  followUps         FollowUp[]
  appointments      Appointment[]
  employeeProfile   EmployeeProfile?
  studentProfile    Student?          @relation("StudentUser")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String?
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum NotificationType {
  LEAD_CREATED
  LEAD_ASSIGNED
  LEAD_CONVERTED
  TASK_REMINDER
  SYSTEM
}

model AgentProfile {
  id          String             @id @default(uuid())
  userId      String             @unique
  companyName String?
  address     String?
  phone       String?
  commission  Float?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  counselors  CounselorProfile[]
}

model CounselorProfile {
  id          String        @id @default(uuid())
  userId      String        @unique
  phone       String?
  department  String?
  designation String?
  salary      Float?
  joiningDate DateTime?
  agentId     String?
  agent       AgentProfile? @relation(fields: [agentId], references: [id])
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Deprecated: Moving to AgentProfile and CounselorProfile
model EmployeeProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  phone       String?
  department  String?
  designation String?
  salary      Float?
  joiningDate DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id                   String           @id @default(uuid())
  name                 String
  firstName            String?
  lastName             String?
  email                String?
  phone                String
  alternateNo          String?
  dateOfBirth          DateTime?
  gender               String?
  nationality          String?
  maritalStatus        String?
  address              String?
  highestQualification String?
  interestedCourse     String?
  testName             String?
  testScore            String?
  interestedCountry    String?
  intake               String?
  applyLevel           String?
  message              String?
  source               String
  data                 Json?
  status               LeadStatus       @default(NEW)
  temperature          LeadTemperature  @default(COLD)
  remark               String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  student              Student?
  activities           LeadActivity[]
  assignments          LeadAssignment[]
  documents            LeadDocument[]
  tasks                LeadTask[]
  imageUrl             String?
  userId               String?          @unique
  user                 User?            @relation("LeadUser", fields: [userId], references: [id])
  followUps            FollowUp[]
  appointments         Appointment[]
  passportNo           String?
  passportIssueDate    DateTime?
  passportExpiryDate   DateTime?
  academicDetails      AcademicDetail[]
  workExperience       WorkExperience[]
  proficiencyExams     Json? // Stores array of selected exams like ["IELTS", "PTE"]

  @@index([phone])
  @@index([status])
  @@index([temperature])
  @@index([firstName])
  @@index([lastName])
}

model FollowUp {
  id             String    @id @default(uuid())
  leadId         String
  userId         String
  type           String // CALL, WHATSAPP, EMAIL, VISIT
  status         String    @default("PENDING") // PENDING, COMPLETED, CANCELLED
  nextFollowUpAt DateTime?
  remark         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
}

model Appointment {
  id          String   @id @default(uuid())
  leadId      String
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
}

model LeadAssignment {
  id         String   @id @default(uuid())
  leadId     String
  assignedTo String
  assignedBy String
  assignedAt DateTime @default(now())
  admin      User     @relation("AssignedBy", fields: [assignedBy], references: [id])
  employee   User     @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: Cascade)
  lead       Lead     @relation(fields: [leadId], references: [id])

  @@index([assignedTo])
  @@index([assignedBy])
  @@index([leadId])
}

model LeadActivity {
  id        String           @id @default(uuid())
  leadId    String
  userId    String
  type      LeadActivityType
  content   String?
  meta      Json?
  createdAt DateTime         @default(now())
  lead      Lead             @relation(fields: [leadId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([type])
}

model LeadTask {
  id          String     @id @default(uuid())
  leadId      String
  assignedTo  String
  title       String
  description String?
  dueAt       DateTime
  status      TaskStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  user        User       @relation(fields: [assignedTo], references: [id])
  lead        Lead       @relation(fields: [leadId], references: [id])
  reminders   Reminder[]

  @@index([assignedTo])
  @@index([leadId])
}

model Reminder {
  id       String   @id @default(uuid())
  taskId   String
  remindAt DateTime
  isSent   Boolean  @default(false)
  sent24h  Boolean  @default(false)
  sent1h   Boolean  @default(false)
  sent10m  Boolean  @default(false)
  task     LeadTask @relation(fields: [taskId], references: [id])
}

model LeadDocument {
  id         String       @id @default(uuid())
  leadId     String
  uploadedBy String
  type       DocumentType
  fileName   String
  fileUrl    String
  createdAt  DateTime     @default(now())
  lead       Lead         @relation(fields: [leadId], references: [id])
  user       User         @relation(fields: [uploadedBy], references: [id])

  @@index([uploadedBy])
  @@index([leadId])
}

model Student {
  id             String        @id @default(uuid())
  leadId         String?       @unique
  name           String
  email          String?
  phone          String
  onboardedBy    String
  status         StudentStatus @default(NEW)
  createdAt      DateTime      @default(now())
  lead           Lead?         @relation(fields: [leadId], references: [id])
  user           User          @relation(fields: [onboardedBy], references: [id])
  imageUrl       String?
  savedAddresses Json?
  studentUserId  String?       @unique
  studentUser    User?         @relation("StudentUser", fields: [studentUserId], references: [id])

  @@index([onboardedBy])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Website {
  id        String   @id @default(uuid())
  name      String   @unique
  url       String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Qualification {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Country {
  id         String                 @id @default(uuid())
  name       String                 @unique
  code       String?                @unique
  isActive   Boolean                @default(true)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  checklists ApplicationChecklist[]
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  SALES_REP
  SUPPORT_AGENT
  STUDENT
  AGENT
  COUNSELOR
}

// LeadSource Enum removed in favor of dynamic Website model / String source

enum LeadStatus {
  NEW
  UNDER_REVIEW
  CONTACTED
  COUNSELLING_SCHEDULED
  COUNSELLING_COMPLETED
  FOLLOWUP_REQUIRED
  INTERESTED
  NOT_INTERESTED
  ON_HOLD
  CLOSED
}

enum StudentStatus {
  NEW
  UNDER_REVIEW
  COUNSELLING_COMPLETED
  COUNSELLING_SCHEDULED
  DOCUMENT_PENDING
  DOCUMENT_VERIFIED
  INTERESTED
  NOT_INTERESTED
  NOT_ELIGIBLE
  ON_HOLD
}

enum ChecklistType {
  MANDATORY
  OPTIONAL
}

model ApplicationChecklist {
  id            String        @id @default(uuid())
  name          String
  type          ChecklistType @default(MANDATORY)
  countryId     String? // Null means "All Countries"
  country       Country?      @relation(fields: [countryId], references: [id])
  isEnquiryForm Boolean       @default(false)
  isMandatory   Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([countryId])
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum LeadActivityType {
  NOTE
  CALL
  EMAIL
  WHATSAPP
  STATUS_CHANGE
  TEMPERATURE_CHANGE
  DOCUMENT_UPLOAD
  TASK_CREATED
  APPOINTMENT
  FOLLOW_UP
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum DocumentType {
  QUOTATION
  REQUIREMENT
  ID_PROOF
  PASSPORT
  ACADEMIC
  PROFICIENCY_TEST
  WORK_EXPERIENCE
  VISA
  OTHER
}

model AcademicDetail {
  id            String   @id @default(uuid())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  qualification String
  stream        String?
  institution   String?
  percentage    String?
  backlogs      String?
  passingYear   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leadId])
}

model WorkExperience {
  id              String   @id @default(uuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  companyName     String
  position        String?
  startDate       String?
  endDate         String?
  totalExperience String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([leadId])
}
